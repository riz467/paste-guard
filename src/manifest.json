{
  "manifest_version": 3,
  "name": "Paste Guard",
  "version": "0.1.0",
  "description": "AIサービスへのペースト時にAPIキー・パスワード等を自動マスク",

  "permissions": ["storage", "activeTab"],

  "host_permissions": [
    "*://claude.ai/*",
    "*://chatgpt.com/*",
    "*://gemini.google.com/*",
    "*://copilot.microsoft.com/*",
    "*://m365.cloud.microsoft/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://claude.ai/*",
        "*://chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://copilot.microsoft.com/*",
        "*://m365.cloud.microsoft/*"
      ],
      "js": ["rules.js", "content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
